<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground for hsnotes.
    Canvas: 108x108. Safe zone: inner 66x66 (centered at 54,54).
    Composition: white notepad page (with top-right corner fold) +
    amber padlock badge bottom-right (signals secure-notes theme).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Page body: rectangle 32,24 -> 76,88 with top-right corner cut for fold -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,24 L68,24 L78,34 L78,86 Q78,90 74,90 L34,90 Q30,90 30,86 L30,28 Q30,24 34,24 Z" />

    <!-- Folded corner shadow triangle -->
    <path
        android:fillColor="#D7DEE8"
        android:pathData="M68,24 L78,34 L68,34 Z" />

    <!-- Note ruling lines (light gray) -->
    <path
        android:fillColor="#9AA5B5"
        android:pathData="M37,44 L65,44 L65,46 L37,46 Z
                          M37,52 L71,52 L71,54 L37,54 Z
                          M37,60 L71,60 L71,62 L37,62 Z
                          M37,68 L60,68 L60,70 L37,70 Z" />

    <!-- Padlock badge body (amber) bottom-right overlay -->
    <path
        android:fillColor="#F5B301"
        android:pathData="M60,74 L80,74 Q82,74 82,76 L82,86 Q82,88 80,88 L60,88 Q58,88 58,86 L58,76 Q58,74 60,74 Z" />

    <!-- Padlock shackle (amber) -->
    <path
        android:strokeColor="#F5B301"
        android:strokeWidth="2.4"
        android:fillColor="#00000000"
        android:pathData="M63,74 L63,70 Q63,65 70,65 Q77,65 77,70 L77,74" />

    <!-- Padlock keyhole (dark dot) -->
    <path
        android:fillColor="#1E293B"
        android:pathData="M70,79 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0 Z" />
</vector>
